datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Servico {
  id    Int    @id @default(autoincrement())
  nome  String
  preco String
}

model Horario {
  id       Int     @id @default(autoincrement())
  hora     String
  status   String  @default("disponivel")
  cliente  String?
  servico  String?
  whatsapp String?
}